# Plantilla de variables de entorno para el pipeline Kafka (Aiven).
# Copia este archivo a .env y rellena los valores reales.
# .env NO debe subirse al repo (está en .gitignore).

# Broker de entrada (host:puerto) desde Aiven > Connection information > Apache Kafka
KAFKA_HOST=kafka-xxxxxxxx.aivencloud.com:16092

# Usuario SASL (Aiven crea "avnadmin" por defecto)
KAFKA_USER=avnadmin

# Contraseña SASL (NUNCA commitear el valor real)
KAFKA_PASSWORD=

# Ruta al certificado CA descargado de Aiven (ca.pem)
KAFKA_CA=ca.pem

# Topic destino de las reseñas nuevas
KAFKA_TOPIC=reviews-nuevas

# (Consumidor / Databricks) checkpoint y tabla Bronze del sink Delta
CHK_PATH=/tmp/_chk/reviews_stream
BRONZE_TABLE=proyecto_bda.bda_schema.bronze_reviews_stream

# (Consumidor) versiones del conector Kafka — deben coincidir con tu runtime Spark
SPARK_VERSION=4.0.2
SCALA_VERSION=2.13
